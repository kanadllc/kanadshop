<footer class="footer" role="contentinfo">
  <div class="page-width">
    <div class="footer__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="footer__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__block-title">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__links" role="list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            <div class="footer__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__block-title">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="footer__text rte">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.show_social -%}
                {%- render 'social-icons' -%}
              {%- endif -%}
            </div>

          {%- when 'newsletter' -%}
            <div class="footer__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__block-title">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.newsletter_text != blank -%}
                <p class="footer__newsletter-text">{{ block.settings.newsletter_text }}</p>
              {%- endif -%}
              {% form 'customer', class: 'newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                  <input
                    type="email"
                    name="contact[email]"
                    class="newsletter-form__input field__input"
                    value="{{ customer.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    placeholder="{{ 'newsletter.label' | t }}"
                    required
                  >
                  <button type="submit" class="button button--primary">
                    {{- 'newsletter.button_label' | t -}}
                  </button>
                </div>
                {%- if form.posted_successfully? -%}
                  <p class="form__message">{{ 'newsletter.success' | t }}</p>
                {%- endif -%}
                {%- if form.errors -%}
                  <p class="form__message form__message--error">{{ form.errors | default_errors }}</p>
                {%- endif -%}
              {% endform %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <small class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}
        {{ powered_by_link }}
      </small>

      {%- if section.settings.payment_enable -%}
        <div class="footer__payment-icons">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "About",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Use this text area to tell your customers about your brand and vision. You can change it in the theme editor.</p>",
          "label": "t:sections.footer.blocks.text.settings.text.label"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.text.settings.show_social.label"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Subscribe to our emails",
          "label": "t:sections.footer.blocks.newsletter.settings.heading.label"
        },
        {
          "type": "text",
          "id": "newsletter_text",
          "default": "Be the first to know about new collections and exclusive offers.",
          "label": "t:sections.footer.blocks.newsletter.settings.newsletter_text.label"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    }
  ]
}
{% endschema %}
