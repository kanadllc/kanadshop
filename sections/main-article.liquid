<article class="section-padding">
  <div class="page-width">
    <nav class="breadcrumbs" aria-label="{{ 'general.breadcrumbs.aria_label' | t }}">
      <ol class="breadcrumbs__list" role="list">
        <li class="breadcrumbs__item"><a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a></li>
        <li class="breadcrumbs__item"><a href="{{ blog.url }}">{{ blog.title }}</a></li>
        <li class="breadcrumbs__item" aria-current="page">{{ article.title }}</li>
      </ol>
    </nav>

    <div class="page-hero" style="background:none; padding:3rem 0 2rem; text-align:left;">
      <h1 class="page-hero__title">{{ article.title }}</h1>
      {%- if section.settings.show_author or section.settings.show_date -%}
        <p style="font-size:1.4rem; opacity:0.6; margin-top:1rem;">
          {%- if section.settings.show_author -%}
            {{ 'sections.blog.by_author' | t: author: article.author }}
          {%- endif -%}
          {%- if section.settings.show_date -%}
            &bull;
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{ article.published_at | date: format: 'month_day_year' }}
            </time>
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>

    {%- if article.image -%}
      <div style="margin-bottom:3rem; border-radius:var(--media-radius,4px); overflow:hidden;">
        {{
          article.image
          | image_url: width: 1200
          | image_tag:
            loading: 'eager',
            sizes: '(min-width: 750px) calc(100vw - 10rem), 100vw',
            widths: '375, 750, 1100, 1500',
            alt: article.image.alt | default: article.title
        }}
      </div>
    {%- endif -%}

    <div class="page-content rte">
      {{ article.content }}
    </div>

    {%- if section.settings.show_tags and article.tags.size > 0 -%}
      <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid rgba(var(--color-base-text),0.1);">
        <p style="font-size:1.4rem; font-weight:600; margin-bottom:1rem;">{{ 'sections.blog.tags_label' | t }}</p>
        <div style="display:flex; gap:0.8rem; flex-wrap:wrap;">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="badge badge--new">{{ tag }}</a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_share_buttons -%}
      <div style="margin-top:3rem;">
        <p style="font-size:1.4rem; font-weight:600; margin-bottom:1rem;">{{ 'sections.article.share' | t }}</p>
        <div style="display:flex; gap:1rem;">
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="button button--secondary">Facebook</a>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="button button--secondary">Twitter</a>
        </div>
      </div>
    {%- endif -%}

    <div style="margin-top:4rem; padding-top:2rem; border-top:1px solid rgba(var(--color-base-text),0.1);">
      <a href="{{ blog.url }}" class="button button--secondary">&larr; {{ 'sections.article.back_to_blog' | t: title: blog.title }}</a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "t:sections.main-article.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_author",
      "default": true,
      "label": "t:sections.main-article.settings.show_author.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.main-article.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "default": true,
      "label": "t:sections.main-article.settings.show_tags.label"
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "default": true,
      "label": "t:sections.main-article.settings.show_share_buttons.label"
    }
  ]
}
{% endschema %}
