<div class="collection-hero">
  <div class="page-width">
    <h1 class="collection-hero__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-hero__description rte">{{ collection.description }}</div>
    {%- endif -%}
  </div>
</div>

<div class="section-padding">
  <div class="page-width">
    <div class="collection-toolbar">
      <p class="collection-toolbar__count">
        {{ 'sections.collection_template.product_count_html' | t: count: collection.products_count }}
      </p>
      {%- if section.settings.enable_sorting -%}
        <div class="collection-toolbar__sort">
          <label for="SortBy">{{ 'sections.collection_template.sort_by_label' | t }}</label>
          <select name="sort_by" id="SortBy" onchange="window.location.search='sort_by='+this.value">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- endif -%}
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="grid grid--{{ section.settings.columns_desktop }}-col grid--2-col-tablet-down">
        {%- for product in collection.products -%}
          <div class="grid__item">
            {%- render 'product-card', product: product -%}
          </div>
        {%- else -%}
          <div class="page-width">
            <p>{{ 'sections.collection_template.empty' | t }}</p>
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="{{ 'general.pagination.label' | t }}">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination__item" aria-label="{{ 'general.pagination.previous' | t }}">
              &lsaquo;
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="pagination__item pagination__item--current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="pagination__item">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination__item" aria-label="{{ 'general.pagination.next' | t }}">
              &rsaquo;
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 12,
      "label": "t:sections.main-collection.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main-collection.settings.enable_filtering.label"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection.settings.enable_sorting.label"
    }
  ]
}
{% endschema %}
