<div class="page-hero">
  <div class="page-width">
    <h1 class="page-hero__title">{{ blog.title }}</h1>
  </div>
</div>

<div class="section-padding">
  <div class="page-width">
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      <div class="blog-grid">
        {%- for article in blog.articles -%}
          <article class="article-card">
            {%- if section.settings.show_image and article.image -%}
              <a href="{{ article.url }}" class="article-card__image">
                {{
                  article.image
                  | image_url: width: 800
                  | image_tag: loading: 'lazy', alt: article.image.alt | default: article.title
                }}
              </a>
            {%- endif -%}
            <div class="article-card__info">
              {%- if section.settings.show_date -%}
                <time class="article-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: format: 'month_day_year' }}
                </time>
              {%- endif -%}
              <h2 class="article-card__title">
                <a href="{{ article.url }}">{{ article.title | escape }}</a>
              </h2>
              {%- if section.settings.show_author -%}
                <p style="font-size:1.3rem; opacity:0.6;">{{ 'sections.blog.by_author' | t: author: article.author }}</p>
              {%- endif -%}
              {%- if section.settings.show_excerpt and article.excerpt != blank -%}
                <p class="article-card__excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" class="article-card__read-more" style="font-size:1.4rem; font-weight:600; margin-top:1rem; display:inline-block;">
                {{ 'sections.blog.read_more' | t }} &rarr;
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="{{ 'general.pagination.label' | t }}">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination__item">&lsaquo;</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="pagination__item pagination__item--current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="pagination__item">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination__item">&rsaquo;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 9,
      "label": "t:sections.main-blog.settings.articles_per_page.label"
    },
    {
      "type": "range",
      "id": "blog_columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-blog.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.main-blog.settings.show_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.main-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": true,
      "label": "t:sections.main-blog.settings.show_author.label"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "t:sections.main-blog.settings.show_excerpt.label"
    }
  ]
}
{% endschema %}
