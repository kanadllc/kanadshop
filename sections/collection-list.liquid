{%- if section.settings.heading != blank -%}
  <div class="featured-collection__header section-padding page-width">
    <h2 class="featured-collection__title">{{ section.settings.heading | escape }}</h2>
  </div>
{%- endif -%}

<div class="page-width">
  <ul class="grid grid--{{ section.settings.columns_desktop }}-col grid--2-col-tablet-down" role="list">
    {%- liquid
      assign collections_to_display = section.settings.collections | default: ''
    -%}
    {%- for block in section.blocks -%}
      {%- assign collection = collections[block.settings.collection] -%}
      <li class="grid__item" {{ block.shopify_attributes }}>
        <a href="{{ collection.url | default: '#' }}" class="collection-card">
          {%- if collection.featured_image != blank or block.settings.image != blank -%}
            <div class="collection-card__image">
              {%- assign card_image = block.settings.image | default: collection.featured_image -%}
              {{
                card_image
                | image_url: width: 800
                | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw', widths: '300, 500, 700, 800'
              }}
            </div>
          {%- else -%}
            <div class="collection-card__image">
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
          <div class="collection-card__overlay"></div>
          <div class="collection-card__info">
            <h3 class="collection-card__title">
              {{- block.settings.title | default: collection.title | escape -}}
            </h3>
            {%- if collection != blank -%}
              <p class="collection-card__count">{{ collection.products_count }} {{ 'sections.collection_list.item_count' | t: count: collection.products_count }}</p>
            {%- endif -%}
          </div>
        </a>
      </li>
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "t:sections.collection-list.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collection-list.settings.heading.label",
      "default": "Collections"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.collection-list.settings.columns_desktop.label"
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "t:sections.collection-list.blocks.featured_collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.collection.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.title.label",
          "info": "t:sections.collection-list.blocks.featured_collection.settings.title.info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.image.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-list.presets.name",
      "blocks": [
        { "type": "featured_collection" },
        { "type": "featured_collection" },
        { "type": "featured_collection" }
      ]
    }
  ]
}
{% endschema %}
