<div class="password-page">
  <div class="password-page__logo">{{ shop.name }}</div>

  <h1 class="password-page__title">{{ 'general.password_page.opening_soon' | t }}</h1>
  <p class="password-page__subtext">{{ 'general.password_page.spread_word' | t }}</p>

  <div class="password-page__form">
    <h2 style="font-size:2rem; margin-bottom:1.5rem;">{{ 'general.password_page.login_form_heading' | t }}</h2>
    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color:red; font-size:1.4rem;">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="field">
        <label for="Password" class="field__label">{{ 'general.password_page.login_form_password_label' | t }}</label>
        <input
          type="password"
          name="password"
          id="Password"
          class="field__input"
          autofocus
          placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
        >
      </div>
      <button type="submit" class="button button--primary button--full-width">
        {{ 'general.password_page.login_form_submit' | t }}
      </button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-password.name",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
