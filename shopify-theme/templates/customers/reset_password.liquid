<section class="section-spacing account-shell" data-editorial-section="customer-reset-password">
  <div class="page-width customer-auth customer-auth--editorial">
    <div class="customer-auth__hero" data-editorial-reveal>
      <p class="account-page__eyebrow">Reset access</p>
      <h1>{{ 'customer.recover_password.title' | t }}</h1>
      <p class="account-page__lead">Choose a new password to restore access to your order history and saved details.</p>
    </div>

    <div class="customer-auth__panel" data-editorial-reveal>
      <h2>{{ 'customer.recover_password.title' | t }}</h2>
      {%- form 'reset_customer_password' -%}
        {{ form.errors | default_errors }}
        <div>
          <label for="ResetPassword">{{ 'customer.activate_account.password' | t }}</label>
          <input id="ResetPassword" type="password" name="customer[password]" autocomplete="new-password" required>
        </div>
        <div>
          <label for="ResetPasswordConfirmation">{{ 'customer.activate_account.password_confirm' | t }}</label>
          <input id="ResetPasswordConfirmation" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
        </div>
        <button class="button" type="submit">{{ 'customer.recover_password.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>