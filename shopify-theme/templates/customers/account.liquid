<section class="section-spacing">
  <div class="page-width account-page">
    <header>
      <h1>Account</h1>
      <p><a href="{{ routes.account_logout_url }}">Log out</a></p>
    </header>

    <div class="account-page__layout">
      <div>
        <h2>Orders</h2>
        {%- if customer.orders_count > 0 -%}
          <div class="search-results-grid">
            {%- for order in customer.orders -%}
              <article class="search-result-card">
                <h3><a href="{{ order.customer_url }}">{{ order.name }}</a></h3>
                <p>{{ order.created_at | time_tag: format: 'date' }}</p>
                <p>{{ order.financial_status_label }}</p>
                <p>{{ order.fulfillment_status_label }}</p>
                <p>{{ order.total_price | money }}</p>
              </article>
            {%- endfor -%}
          </div>
        {%- else -%}
          <p>No orders yet.</p>
        {%- endif -%}
      </div>

      <aside class="cart-summary">
        <h2>Account details</h2>
        {{ customer.default_address | format_address }}
        <p><a href="{{ routes.account_addresses_url }}">Manage addresses</a></p>
      </aside>
    </div>
  </div>
</section>