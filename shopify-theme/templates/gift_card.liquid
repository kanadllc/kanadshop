{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }} gift card</title>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
    {{ content_for_header }}
  </head>
  <body class="gift-card-page">
    <main class="section-spacing">
      <div class="page-width gift-card-page__inner">
        <h1>{{ shop.name }}</h1>
        <p>{{ gift_card.initial_value | money }}</p>
        <p>{{ gift_card.code | format_code }}</p>

        <div class="gift-card-page__qr" id="GiftCardQrCode"></div>

        {%- if gift_card.pass_url -%}
          <a class="button" href="{{ gift_card.pass_url }}">Add to Apple Wallet</a>
        {%- endif -%}
      </div>
    </main>

    <script>
      new QRCode(document.getElementById('GiftCardQrCode'), {
        text: '{{ shop.url }}',
        width: 120,
        height: 120
      });
    </script>
  </body>
</html>