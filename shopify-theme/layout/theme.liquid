<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'seo-meta-tags' %}

    <style>
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
      {{ settings.type_heading_font | font_face: font_display: 'swap' }}
      {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}

      :root {
        --color-primary: {{ settings.color_heading }};
        --color-secondary: #ffffff;
        --color-accent: {{ settings.color_accent }};
        --color-text: {{ settings.color_foreground }};
        --color-background: {{ settings.color_background }};
        --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-heading: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
      }
    </style>

    {{ content_for_header }}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme-interactions.js' | asset_url }}" defer></script>
    <script src="{{ 'recipient-form.js' | asset_url }}" defer></script>
    <script>
      window.accessibilityStrings = {
        recipientFormExpanded: {{ 'accessibility.recipient_form.expanded' | t | json }},
        recipientFormCollapsed: {{ 'accessibility.recipient_form.collapsed' | t | json }},
        predictiveSearchResults: {{ 'accessibility.predictive_search.results' | t | json }},
        predictiveSearchNoResults: {{ 'accessibility.predictive_search.no_results' | t | json }}
      };
    </script>
  </head>

  <body class="template-{{ template.name | handle }}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      Skip to content
    </a>

    {%- unless template.name == 'password' -%}
      {% sections 'header-group' %}
    {%- endunless -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- unless template.name == 'password' -%}
      {% sections 'footer-group' %}
    {%- endunless -%}
  </body>
</html>
