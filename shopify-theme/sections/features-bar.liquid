<div class="features-bar">
  <div class="features-bar__inner">
    <div class="features-bar__grid">
      {%- for block in section.blocks -%}
        <div class="feature-item" {{ block.shopify_attributes }}>
          <div class="feature-item__icon">
            {%- if block.settings.icon == 'truck' -%}
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
            {%- elsif block.settings.icon == 'shield' -%}
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- elsif block.settings.icon == 'clock' -%}
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- elsif block.settings.icon == 'credit-card' -%}
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            {%- else -%}
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            {%- endif -%}
          </div>
          <div class="feature-item__content">
            <h4 class="feature-item__title">{{ block.settings.title | escape }}</h4>
            <p class="feature-item__text">{{ block.settings.text | escape }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Features Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "clock", "label": "Clock" },
            { "value": "credit-card", "label": "Credit Card" },
            { "value": "info", "label": "Info" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Bar",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "title": "Free Shipping", "text": "For all orders over $50" } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Secure Payment", "text": "100% secure payment" } },
        { "type": "feature", "settings": { "icon": "clock", "title": "24/7 Support", "text": "Dedicated support" } },
        { "type": "feature", "settings": { "icon": "credit-card", "title": "Money Back", "text": "If goods have problems" } }
      ]
    }
  ]
}
{% endschema %}
