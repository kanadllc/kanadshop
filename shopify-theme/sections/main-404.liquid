<section class="empty-state section-spacing">
  <div class="page-width empty-state__inner">
    <h1>Page not found</h1>
    <p>The page you were looking for does not exist or has moved.</p>
    <div class="empty-state__actions">
      <a class="button" href="{{ routes.root_url }}">Return home</a>
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-inline-form">
        <label class="visually-hidden" for="Search404-{{ section.id }}">Search the store</label>
        <input id="Search404-{{ section.id }}" type="search" name="q" placeholder="Search the store">
        <button type="submit">Search</button>
      </form>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "presets": [
    {
      "name": "404"
    }
  ]
}
{% endschema %}