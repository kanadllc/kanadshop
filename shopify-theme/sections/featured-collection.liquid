{{ 'theme.css' | asset_url | stylesheet_tag }}

{%- assign collection = collections[section.settings.collection] -%}

<div class="featured-collection" data-editorial-section="featured-collection">
  <div class="featured-collection__inner">
    <div class="section-header section-header--featured" data-editorial-reveal>
      <div>
        <p class="section-header__eyebrow">Curated spotlight</p>
        {% if section.settings.title != blank %}
          <h2 class="featured-collection__title">{{ section.settings.title | escape }}</h2>
        {% endif %}
      </div>
      <div class="featured-collection__intro-copy">
        {% comment %}This keeps the original collection-driven logic intact while framing products like premium fashion and pet-edit recommendations.{% endcomment %}
        <p>{% if collection != blank %}A polished edit from {{ collection.title | escape }} designed to read like a campaign, not a plain product grid.{% else %}Use this featured edit to spotlight hero products, outfit builders, or premium pet essentials with stronger storytelling.{% endif %}</p>
      </div>
    </div>

  <div class="featured-collection__grid">
    {%- if collection != blank and collection.products_count > 0 -%}
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <article class="product-card" data-editorial-reveal>
          <a href="{{ product.url }}" class="product-card__media">
            {%- if product.featured_image -%}
              <img class="product-card__image"
                   src="{{ product.featured_image | image_url: width: 500 }}"
                   alt="{{ product.featured_image.alt | escape }}"
                   loading="lazy"
                   width="500"
                   height="{{ 500 | divided_by: product.featured_image.aspect_ratio | ceil }}">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
            {%- endif -%}
            <span class="product-card__badge">{% if product.available %}In demand{% else %}Sold out{% endif %}</span>
          </a>
          <div class="product-card__info">
            <div class="product-card__meta">
              {%- if product.vendor != blank -%}
                <span>{{ product.vendor | escape }}</span>
              {%- endif -%}
              {%- if product.type != blank -%}
                <span>{{ product.type | escape }}</span>
              {%- endif -%}
            </div>
            <h3 class="product-card__title">
              <a href="{{ product.url }}">{{ product.title | escape }}</a>
            </h3>
            <div class="product-card__price-row">
              <div class="product-card__price">
              {%- if product.price_varies -%}
                {{ product.price_min | money }} - {{ product.price_max | money }}
              {%- else -%}
                {{ product.price | money }}
              {%- endif -%}
              {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
                <p class="product-card__unit-price">
                  Unit price: {{ product.selected_or_first_available_variant.unit_price | money }}
                  /
                  {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
                    {{ product.selected_or_first_available_variant.unit_price_measurement.reference_value }}
                  {%- endif -%}
                  {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
                </p>
              {%- endif -%}
              </div>
              {%- if product.compare_at_price_max > product.price -%}
                <span class="product-card__compare">{{ product.compare_at_price_max | minus: product.price | money }} off</span>
              {%- endif -%}
            </div>

            {% comment %}Preserves the original add-to-cart form and variant submission while improving the product-card presentation only.{% endcomment %}
            <form method="post" action="{{ routes.cart_add_url }}" class="product-card__form">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" class="product-card__add-btn" {% unless product.available %}disabled{% endunless %}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                {% if product.available %}Add to cart{% else %}Sold out{% endif %}
              </button>
            </form>
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        <article class="product-card" data-editorial-reveal>
          <div class="product-card__media">
            {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__image' }}
            <span class="product-card__badge">Featured pick</span>
          </div>
          <div class="product-card__info">
            <div class="product-card__meta"><span>Example brand</span><span>Category</span></div>
            <h3 class="product-card__title">Example Product {{ i }}</h3>
            <div class="product-card__price-row">
              <div class="product-card__price">$19.99</div>
            </div>
            <button type="button" class="product-card__add-btn" disabled>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              Add to cart
            </button>
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Featured collection",
      "label": "Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
