<section class="password-page section-spacing">
  <div class="page-width password-page__inner">
    <h1>{{ shop.name }}</h1>

    {%- if shop.password_message != blank -%}
      <div class="rte">{{ shop.password_message }}</div>
    {%- endif -%}

    {%- form 'storefront_password', class: 'password-form' -%}
      {{ form.errors | default_errors }}
      <label for="Password-{{ section.id }}">Store password</label>
      <input id="Password-{{ section.id }}" type="password" name="password" autocomplete="current-password" required>
      <button class="button" type="submit">Enter store</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "presets": [
    {
      "name": "Password"
    }
  ]
}
{% endschema %}