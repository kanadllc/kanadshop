<section class="hero-slider hero-slider--{{ section.settings.height }}" data-autoplay="{{ section.settings.autoplay }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}" data-pause-on-hover="{{ section.settings.pause_on_hover }}">
  <div class="hero-slider__shell page-width">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.description != blank or section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank -%}
      <div class="hero-slider__intro text-{{ section.settings.content_alignment }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero-slider__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hero-slider__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="hero-slider__description rte">{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank -%}
          <a href="{{ section.settings.secondary_button_link }}" class="hero-slider__secondary-link">
            {{ section.settings.secondary_button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  <div class="hero-slider__track">
    {%- for block in section.blocks -%}
      <article class="hero-slide color-scheme-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img 
            src="{{ block.settings.image | image_url: width: 2000 }}" 
            alt="{{ block.settings.image.alt | escape }}"
            class="hero-slide__image"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            width="2000"
            height="{{ 2000 | divided_by: block.settings.image.aspect_ratio | ceil }}"
          >
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'hero-slide__image placeholder-svg' }}
        {%- endif -%}
        
        <div class="hero-slide__overlay"></div>
        
        <div class="hero-slide__content-wrapper">
          <div class="hero-slide__content text-{{ block.settings.text_alignment }}">
            {%- if block.settings.kicker != blank -%}
              <p class="hero-slide__kicker">{{ block.settings.kicker | escape }}</p>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <p class="hero-slide__subheading">{{ block.settings.subheading | escape }}</p>
            {%- endif -%}
            
            {%- if block.settings.title != blank -%}
              <h2 class="hero-slide__title">{{ block.settings.title | escape }}</h2>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="hero-slide__text rte">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if block.settings.badge_1 != blank or block.settings.badge_2 != blank or block.settings.badge_3 != blank -%}
              <ul class="hero-slide__badges" role="list">
                {%- if block.settings.badge_1 != blank -%}
                  <li>{{ block.settings.badge_1 | escape }}</li>
                {%- endif -%}
                {%- if block.settings.badge_2 != blank -%}
                  <li>{{ block.settings.badge_2 | escape }}</li>
                {%- endif -%}
                {%- if block.settings.badge_3 != blank -%}
                  <li>{{ block.settings.badge_3 | escape }}</li>
                {%- endif -%}
              </ul>
            {%- endif -%}
            
            {%- if block.settings.button_label != blank and block.settings.button_link != blank or block.settings.secondary_button_label != blank and block.settings.secondary_button_link != blank -%}
              <div class="hero-slide__actions">
                {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                  <a href="{{ block.settings.button_link }}" class="hero-slide__button button">
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
                {%- if block.settings.secondary_button_label != blank and block.settings.secondary_button_link != blank -%}
                  <a href="{{ block.settings.secondary_button_link }}" class="hero-slide__button hero-slide__button--secondary">
                    {{ block.settings.secondary_button_label | escape }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if block.settings.metric_label != blank and block.settings.metric_value != blank -%}
              <div class="hero-slide__metric" aria-label="{{ block.settings.metric_label | escape }}">
                <strong>{{ block.settings.metric_value | escape }}</strong>
                <span>{{ block.settings.metric_label | escape }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      </article>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="hero-slider__arrow hero-slider__arrow--prev" aria-label="Previous slide">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button class="hero-slider__arrow hero-slider__arrow--next" aria-label="Next slide">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    
    <div class="hero-slider__dots">
      {%- for block in section.blocks -%}
        <button class="hero-slider__dot {% if forloop.first %}is-active{% endif %}" aria-label="Go to slide {{ forloop.index }}" data-index="{{ forloop.index0 }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
    {%- if section.settings.show_scroll_hint -%}
      <div class="hero-slider__scroll-hint" aria-hidden="true">
        <span>{{ section.settings.scroll_hint_label | escape }}</span>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sliders = document.querySelectorAll('.hero-slider');
    
    sliders.forEach(slider => {
      const track = slider.querySelector('.hero-slider__track');
      const slides = slider.querySelectorAll('.hero-slide');
      const prevBtn = slider.querySelector('.hero-slider__arrow--prev');
      const nextBtn = slider.querySelector('.hero-slider__arrow--next');
      const dots = slider.querySelectorAll('.hero-slider__dot');
      
      if (slides.length <= 1) return;
      
      let currentIndex = 0;
      const autoplay = slider.dataset.autoplay === 'true';
      const speed = parseInt(slider.dataset.speed, 10) || 5000;
      const pauseOnHover = slider.dataset.pauseOnHover === 'true';
      let interval;
      
      function goToSlide(index) {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;
        
        track.style.transform = `translateX(-${index * 100}%)`;
        
        dots.forEach(dot => dot.classList.remove('is-active'));
        if(dots[index]) dots[index].classList.add('is-active');
        
        currentIndex = index;
      }
      
      function nextSlide() { goToSlide(currentIndex + 1); }
      function prevSlide() { goToSlide(currentIndex - 1); }
      
      if (prevBtn) prevBtn.addEventListener('click', () => { prevSlide(); resetAutoplay(); });
      if (nextBtn) nextBtn.addEventListener('click', () => { nextSlide(); resetAutoplay(); });
      
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          goToSlide(index);
          resetAutoplay();
        });
      });
      
      function startAutoplay() {
        if (autoplay) {
          interval = setInterval(nextSlide, speed);
        }
      }
      
      function resetAutoplay() {
        clearInterval(interval);
        startAutoplay();
      }

      if (pauseOnHover && autoplay) {
        slider.addEventListener('mouseenter', () => clearInterval(interval));
        slider.addEventListener('mouseleave', startAutoplay);
      }
      
      startAutoplay();
    });
  });
</script>

{% schema %}
{
