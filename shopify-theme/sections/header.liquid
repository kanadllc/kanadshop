<header class="header">
  <div class="header__top-bar">
    <div class="header__top-bar-inner">
      <div class="header__top-left">
        {%- if section.settings.contact_phone != blank -%}
          <a href="tel:{{ section.settings.contact_phone | remove: ' ' }}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {{ section.settings.contact_phone }}
          </a>
        {%- endif -%}
        {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            {{ section.settings.contact_email }}
          </a>
        {%- endif -%}
      </div>
      <div class="header__top-right">
        {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          <localization-form class="header__localization">
            {%- form 'localization', id: 'HeaderLocalizationForm' -%}
              {%- if localization.available_countries.size > 1 -%}
                <div class="header__localization-group disclosure">
                  <button type="button" class="disclosure__button" aria-expanded="false" aria-controls="HeaderCountryList">
                    {{ localization.country.name }} ({{ localization.country.currency.iso_code }})
                  </button>
                  <ul id="HeaderCountryList" class="disclosure__list" hidden>
                    {%- for country in localization.available_countries -%}
                      <li>
                        <a href="#" data-value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %}>
                          {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                  <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
                </div>
              {%- endif -%}

              {%- if localization.available_languages.size > 1 -%}
                <div class="header__localization-group disclosure">
                  <button type="button" class="disclosure__button" aria-expanded="false" aria-controls="HeaderLanguageList">
                    {{ localization.language.endonym_name | capitalize }}
                  </button>
                  <ul id="HeaderLanguageList" class="disclosure__list" hidden>
                    {%- for language in localization.available_languages -%}
                      <li>
                        <a href="#" data-value="{{ language.iso_code }}" lang="{{ language.iso_code }}" hreflang="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}>
                          {{ language.endonym_name | capitalize }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                  <input type="hidden" name="language_code" value="{{ localization.language.iso_code }}">
                </div>
              {%- endif -%}
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {% if customer %}
          <a href="{{ routes.account_url }}">Account</a>
        {% else %}
          <a href="{{ routes.account_login_url }}">Log in</a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="header__inner">
    <div class="header__left">
      <div class="header__logo">
        <a href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            <img
              src="{{ settings.logo | image_url: width: 320 }}"
              alt="{{ settings.logo.alt | default: shop.name | escape }}"
              loading="eager"
              width="{{ settings.logo.width }}"
              height="{{ settings.logo.height }}"
            >
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>
      </div>

      <div class="header__categories-wrapper">
        <button class="categories-btn" type="button" aria-expanded="false" aria-controls="HeaderCategoryMenu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <span>Browse Categories</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="categories-btn__icon"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div class="vertical-mega-menu" id="HeaderCategoryMenu">
          <ul class="vertical-mega-menu__list">
            {%- for link in linklists[section.settings.menu].links -%}
              <li class="vertical-mega-menu__item {% if link.links != blank %}has-submenu{% endif %}">
                <a href="{{ link.url }}" class="vertical-mega-menu__link">
                  <span>{{ link.title }}</span>
                  {%- if link.links != blank -%}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  {%- endif -%}
                </a>

                {%- if link.links != blank -%}
                  <div class="submenu-pane">
                    <div class="submenu-pane__inner">
                      {%- for childlink in link.links -%}
                        <div class="submenu-pane__column">
                          <a href="{{ childlink.url }}" class="submenu-pane__title">{{ childlink.title }}</a>
                          {%- if childlink.links != blank -%}
                            <ul class="submenu-pane__list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a href="{{ grandchildlink.url }}" class="submenu-pane__link">{{ grandchildlink.title }}</a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                      
                      {%- if section.settings.mega_menu_image != blank and forloop.first -%}
                        <div class="submenu-pane__promo">
                          <span class="submenu-pane__promo-label">{{ section.settings.mega_menu_promo_text }}</span>
                          <img src="{{ section.settings.mega_menu_image | image_url: width: 300 }}" alt="{{ section.settings.mega_menu_image.alt }}" loading="lazy" width="300" height="{{ 300 | divided_by: section.settings.mega_menu_image.aspect_ratio | ceil }}">
                          {%- if section.settings.mega_menu_promo_link_text != blank -%}
                            <a href="{{ section.settings.mega_menu_promo_link }}" class="submenu-pane__promo-link">{{ section.settings.mega_menu_promo_link_text }}</a>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>

    <div class="header__right">
      <predictive-search class="header__search">
        <form action="{{ routes.search_url }}" method="get" role="search" class="header__search-form">
          <div class="search__input-wrapper">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search__icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input
              class="search__input"
              id="HeaderSearchInput"
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="{{ 'general.search.placeholder' | t }}"
              role="combobox"
              aria-expanded="false"
              aria-owns="predictive-search-results"
              aria-controls="predictive-search-results"
              aria-haspopup="listbox"
              aria-autocomplete="list"
            >
            <input type="hidden" name="options[prefix]" value="last">
          </div>
          <div class="predictive-search-results" data-predictive-search tabindex="-1" aria-label="{{ 'general.search.submit' | t }}"></div>
        </form>
      </predictive-search>

      <div class="header__icons">
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="header__icon-link">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="header__icon-text">Account</span>
        </a>

        <a href="{{ routes.cart_url }}" class="header__icon-link">
          <div class="header__icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span class="header__icon-badge" id="cart-icon-bubble">{{ cart.item_count }}</span>
          </div>
          <span class="header__icon-text">Cart</span>
        </a>
      </div>
    </div>
  </div>

  {%- if linklists[section.settings.menu].links != blank -%}
    <nav class="header__nav-shell" aria-label="Primary">
      <div class="header__nav-inner">
        <ul class="header__nav-list" role="list">
          {%- for link in linklists[section.settings.menu].links -%}
            <li class="header__nav-item {% if link.links != blank %}header__nav-item--has-mega{% endif %}">
              <a
                href="{{ link.url }}"
                class="header__nav-link"
                {% if link.current %}aria-current="page"{% endif %}
              >
                <span>{{ link.title }}</span>
                {%- if link.links != blank -%}
                  <svg class="header__nav-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
                {%- endif -%}
              </a>

              {%- if link.links != blank -%}
                <div class="header__mega-panel">
                  <div class="header__mega-panel-inner">
                    <div class="header__mega-columns">
                      {%- for childlink in link.links -%}
                        <div class="header__mega-column">
                          <a href="{{ childlink.url }}" class="header__mega-title">{{ childlink.title }}</a>
                          {%- if childlink.links != blank -%}
                            <ul class="header__mega-list" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a href="{{ grandchildlink.url }}" class="header__mega-link">{{ grandchildlink.title }}</a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </div>

                    {%- if section.settings.mega_menu_image != blank -%}
                      <aside class="header__mega-promo">
                        {%- if section.settings.mega_menu_promo_text != blank -%}
                          <span class="header__mega-promo-label">{{ section.settings.mega_menu_promo_text }}</span>
                        {%- endif -%}
                        <img src="{{ section.settings.mega_menu_image | image_url: width: 360 }}" alt="{{ section.settings.mega_menu_image.alt }}" loading="lazy" width="360" height="{{ 360 | divided_by: section.settings.mega_menu_image.aspect_ratio | ceil }}">
                        {%- if section.settings.mega_menu_promo_link_text != blank and section.settings.mega_menu_promo_link != blank -%}
                          <a href="{{ section.settings.mega_menu_promo_link }}" class="header__mega-promo-link">{{ section.settings.mega_menu_promo_link_text }}</a>
                        {%- endif -%}
                      </aside>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </nav>
  {%- endif -%}
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Main menu"
    },
    {
      "type": "header",
      "content": "Top bar contact"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone number",
      "default": "+1 234 567 890"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email address",
      "default": "support@kanadshop.com"
    },
    {
      "type": "header",
      "content": "Promotion"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_image",
      "label": "Promotion image"
    },
    {
      "type": "text",
      "id": "mega_menu_promo_text",
      "label": "Promotion label",
      "default": "New arrival"
    },
    {
      "type": "text",
      "id": "mega_menu_promo_link_text",
      "label": "Promotion link text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "mega_menu_promo_link",
      "label": "Promotion link"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
