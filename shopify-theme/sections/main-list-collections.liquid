<section class="section-spacing collection-directory" data-editorial-section="collections-directory">
  <div class="page-width">
    <header class="collection-directory__header" data-editorial-reveal>
      <div>
        <p class="collection-directory__eyebrow">The collections</p>
        <h1>Curated Selection.</h1>
      </div>
      <p class="collection-directory__lead">A dialogue between texture and form. Explore the atelier's foundational pillars of modern living.</p>
    </header>

    {%- paginate collections by 12 -%}
      <div class="collection-list-grid">
        {%- for collection in collections -%}
          <article class="collection-list-card" data-editorial-reveal>
            <a href="{{ collection.url }}" class="collection-list-card__media">
              {%- if collection.featured_image -%}
                <img src="{{ collection.featured_image | image_url: width: 720 }}" alt="{{ collection.featured_image.alt | escape | default: collection.title | escape }}" loading="lazy" width="720" height="{{ 720 | divided_by: collection.featured_image.aspect_ratio | ceil }}">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <div class="collection-list-card__content">
              <div class="collection-list-card__meta">
                <h2>{{ collection.title }}</h2>
                <span>{{ forloop.index | prepend: '0' }}</span>
              </div>
              <p>{{ collection.description | default: 'A curated edit shaped around quality, atmosphere, and considered everyday use.' | strip_html | truncatewords: 24 }}</p>
              <a href="{{ collection.url }}" class="collection-list-card__cta">Discover {{ collection.title | escape }} <span aria-hidden="true">↗</span></a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Collections pagination">
          {{ paginate | default_pagination }}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "presets": [
    {
      "name": "Collection list"
    }
  ]
}
{% endschema %}