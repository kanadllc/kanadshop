<footer class="footer">
  {%- liquid
    assign has_social_links = false
    if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank
      assign has_social_links = true
    endif
  -%}
  <div class="footer__inner">
    <div class="footer__blocks">
      <div class="footer__block">
        {%- if section.settings.heading != blank -%}
          <h3 class="footer__title">{{ section.settings.heading | escape }}</h3>
        {%- endif -%}
        <div class="footer__text">
          {{ section.settings.body_text }}
        </div>
      </div>

      <div class="footer__block">
        <h3 class="footer__title">Quick links</h3>
        {%- if section.settings.menu != blank -%}
          <ul class="footer__menu">
            {%- for link in linklists[section.settings.menu].links -%}
              <li>
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- if section.settings.show_newsletter -%}
        <div class="footer__block footer__newsletter">
          {%- if section.settings.newsletter_heading != blank -%}
            <h3 class="footer__title">{{ section.settings.newsletter_heading | escape }}</h3>
          {%- endif -%}
          {%- if section.settings.newsletter_text != blank -%}
            <p>{{ section.settings.newsletter_text | escape }}</p>
          {%- endif -%}
          {%- form 'customer', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">Email address</label>
            <input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" class="newsletter__input" placeholder="Email address" value="{{ form.email }}" autocorrect="off" autocapitalize="off" required>
            <button type="submit" class="newsletter__button">Subscribe</button>
            {%- if form.posted_successfully? -%}
              <p class="form-status" tabindex="-1">Thanks for subscribing.</p>
            {%- endif -%}
            {{ form.errors | default_errors }}
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_follow_on_shop -%}
        <div class="footer__block">
          <h3 class="footer__title">Follow on Shop</h3>
          <div class="footer__follow-on-shop">
            {{ shop | login_button: action: 'follow' }}
          </div>
        </div>
      {%- endif -%}
    </div>

      {%- if section.settings.show_social_icons and has_social_links -%}
      <div class="footer__social">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="footer__social-link" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.7-1.6H16.7V4.8c-.3 0-1.2-.1-2.3-.1-2.3 0-3.9 1.4-3.9 4V11H8v3h2.5v8h3z" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="footer__social-link" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm10.5 1.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="footer__social-link" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.8 7.2a2.8 2.8 0 0 0-2-2C18 4.7 12 4.7 12 4.7s-6 0-7.8.5a2.8 2.8 0 0 0-2 2A29.6 29.6 0 0 0 1.7 12c0 1.6.2 3.2.5 4.8a2.8 2.8 0 0 0 2 2c1.8.5 7.8.5 7.8.5s6 0 7.8-.5a2.8 2.8 0 0 0 2-2c.3-1.6.5-3.2.5-4.8s-.2-3.2-.5-4.8zM10 15.5v-7l6 3.5-6 3.5z" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3c.3 2.2 1.7 3.8 4 4v2.7c-1.7 0-3.1-.5-4-1.3v6.1a5.5 5.5 0 1 1-5.5-5.5c.4 0 .8 0 1.2.1v2.8a2.7 2.7 0 1 0 1.5 2.6V3H14z" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="footer__bottom">
      <div class="footer__copyright">
        &copy; {{ 'now' | date: "%Y" }} {{ shop.name | link_to: routes.root_url }}. All rights reserved.
      </div>

      {%- if shop.enabled_payment_types.size > 0 -%}
        <ul class="footer__payment-types" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
        <localization-form class="footer__localization">
          {%- form 'localization', id: 'FooterLocalizationForm' -%}
            {%- if localization.available_countries.size > 1 -%}
              <div class="footer__localization-group disclosure">
                <button type="button" class="disclosure__button" aria-expanded="false" aria-controls="FooterCountryList">
                  {{ localization.country.name }} ({{ localization.country.currency.iso_code }})
                </button>
                <ul id="FooterCountryList" class="disclosure__list" hidden>
                  {%- for country in localization.available_countries -%}
                    <li><a href="#" data-value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %}>{{ country.name }} ({{ country.currency.iso_code }})</a></li>
                  {%- endfor -%}
                </ul>
                <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
              </div>
            {%- endif -%}
            {%- if localization.available_languages.size > 1 -%}
              <div class="footer__localization-group disclosure">
                <button type="button" class="disclosure__button" aria-expanded="false" aria-controls="FooterLanguageList">
                  {{ localization.language.endonym_name | capitalize }}
                </button>
                <ul id="FooterLanguageList" class="disclosure__list" hidden>
                  {%- for language in localization.available_languages -%}
                    <li><a href="#" data-value="{{ language.iso_code }}" lang="{{ language.iso_code }}" hreflang="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}>{{ language.endonym_name | capitalize }}</a></li>
                  {%- endfor -%}
                </ul>
                <input type="hidden" name="language_code" value="{{ localization.language.iso_code }}">
              </div>
            {%- endif -%}
          {%- endform -%}
        </localization-form>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About the shop"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Share store details, promotions, or brand content with your customers.</p>"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter sign-up",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Subscribe to our emails"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter subheading",
      "default": "A short sentence describing what someone will receive by subscribing"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social media icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_follow_on_shop",
      "label": "Show Follow on Shop button",
      "default": true
    }
  ]
}
{% endschema %}
