{{ 'theme.css' | asset_url | stylesheet_tag }}

{%- assign collection = collections[section.settings.collection] -%}

<section class="pop-products" data-editorial-section="popular-products">
  <div class="pop-products__inner page-width">

    <header class="pop-products__header" data-editorial-reveal>
      <div class="pop-products__header-left">
        {%- if section.settings.eyebrow != blank -%}
          <p class="pop-products__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="pop-products__title">{{ section.settings.title | default: 'Popular Products' | escape }}</h2>
      </div>
      <div class="pop-products__header-right">
        {%- if section.settings.description != blank -%}
          <p class="pop-products__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
        {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
          <a href="{{ section.settings.view_all_link }}" class="pop-products__viewall">
            <span>{{ section.settings.view_all_label | escape }}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>
    </header>

    <div class="pop-products__grid">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <article class="pop-card" data-editorial-reveal style="--card-index: {{ forloop.index0 }}">
            <a href="{{ product.url }}" class="pop-card__media-link" tabindex="-1" aria-hidden="true">
              <div class="pop-card__media">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="pop-card__image"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | divided_by: product.featured_image.aspect_ratio | ceil }}"
                  >
                {%- else -%}
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'pop-card__image pop-card__image--placeholder' }}
                {%- endif -%}
                <div class="pop-card__rank" aria-hidden="true">{{ forloop.index | prepend: '0' }}</div>
                {%- if product.compare_at_price_max > product.price -%}
                  <span class="pop-card__sale-badge">Sale</span>
                {%- elsif forloop.index == 1 -%}
                  <span class="pop-card__sale-badge pop-card__sale-badge--hot">Hot</span>
                {%- endif -%}
              </div>
            </a>
            <div class="pop-card__body">
              <div class="pop-card__meta">
                {%- if product.vendor != blank -%}
                  <span class="pop-card__vendor">{{ product.vendor | escape }}</span>
                {%- endif -%}
                {%- if product.available -%}
                  <span class="pop-card__stock">In stock</span>
                {%- else -%}
                  <span class="pop-card__stock pop-card__stock--out">Sold out</span>
                {%- endif -%}
              </div>
              <h3 class="pop-card__name">
                <a href="{{ product.url }}">{{ product.title | escape }}</a>
              </h3>
              <div class="pop-card__footer">
                <div class="pop-card__pricing">
                  <span class="pop-card__price">
                    {%- if product.price_varies -%}
                      From {{ product.price_min | money }}
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </span>
                  {%- if product.compare_at_price_max > product.price -%}
                    <s class="pop-card__was">{{ product.compare_at_price_max | money }}</s>
                  {%- endif -%}
                </div>
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button
                    type="submit"
                    class="pop-card__add"
                    aria-label="Add {{ product.title | escape }} to cart"
                    {% unless product.available %}disabled{% endunless %}
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </form>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- assign placeholder_titles = 'The Signature Harness,Venice Collar,Transatlantique Carrier,The Antler Bowl' | split: ',' -%}
        {%- assign placeholder_prices = '$145,$89,$380,$62' | split: ',' -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <article class="pop-card" data-editorial-reveal style="--card-index: {{ forloop.index0 }}">
            <div class="pop-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'pop-card__image pop-card__image--placeholder' }}
              <div class="pop-card__rank" aria-hidden="true">{{ forloop.index | prepend: '0' }}</div>
              {%- if forloop.index == 1 -%}<span class="pop-card__sale-badge pop-card__sale-badge--hot">Hot</span>{%- endif -%}
            </div>
            <div class="pop-card__body">
              <div class="pop-card__meta">
                <span class="pop-card__vendor">KANAD Pet</span>
                <span class="pop-card__stock">In stock</span>
              </div>
              <h3 class="pop-card__name"><a href="#">{{ placeholder_titles[forloop.index0] | default: 'Premium Product' }}</a></h3>
              <div class="pop-card__footer">
                <div class="pop-card__pricing">
                  <span class="pop-card__price">{{ placeholder_prices[forloop.index0] | default: '$99' }}</span>
                </div>
                <button type="button" class="pop-card__add" disabled aria-label="Add to cart">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Popular Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Customer Favourites"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Popular Products"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "The pieces our community returns to, season after season."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Popular Products"
    }
  ]
}
{% endschema %}
