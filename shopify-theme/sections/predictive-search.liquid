{%- if predictive_search.performed -%}
  <div id="predictive-search-results" class="predictive-search__results" role="listbox">
    {%- if predictive_search.resources.queries.size > 0 -%}
      <div class="predictive-search__group">
        <h3>Suggestions</h3>
        <ul role="list">
          {%- for query in predictive_search.resources.queries -%}
            <li role="option"><a href="{{ routes.search_url }}?q={{ query.text | url_encode }}">{{ query.styled_text }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.products.size > 0 -%}
      <div class="predictive-search__group">
        <h3>Products</h3>
        <ul role="list">
          {%- for product in predictive_search.resources.products -%}
            <li role="option">
              <a href="{{ product.url }}">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.featured_image.alt | escape | default: product.title | escape }}" loading="lazy" width="60" height="{{ 60 | divided_by: product.featured_image.aspect_ratio | ceil }}">
                {%- endif -%}
                <span>{{ product.title }}</span>
                <strong>{{ product.price | money }}</strong>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.collections.size > 0 -%}
      <div class="predictive-search__group">
        <h3>Collections</h3>
        <ul role="list">
          {%- for collection in predictive_search.resources.collections -%}
            <li role="option"><a href="{{ collection.url }}">{{ collection.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.pages.size > 0 -%}
      <div class="predictive-search__group">
        <h3>Pages</h3>
        <ul role="list">
          {%- for page in predictive_search.resources.pages -%}
            <li role="option"><a href="{{ page.url }}">{{ page.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if predictive_search.resources.articles.size > 0 -%}
      <div class="predictive-search__group">
        <h3>Articles</h3>
        <ul role="list">
          {%- for article in predictive_search.resources.articles -%}
            <li role="option"><a href="{{ article.url }}">{{ article.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="predictive-search__footer">
      <button type="submit" class="button">Search for “{{ predictive_search.terms }}”</button>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Predictive search",
  "settings": []
}
{% endschema %}