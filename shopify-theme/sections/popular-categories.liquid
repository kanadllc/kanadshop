<section class="popular-categories color-scheme-{{ section.settings.color_scheme }}">
  <div class="popular-categories__inner page-width">
    <div class="section-header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
      <h2 class="section-header__title">{{ section.settings.title | escape }}</h2>
        {%- if section.settings.description != blank -%}
          <div class="section-header__description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="section-header__link">View all</a>
      {%- endif -%}
    </div>
    
    <div class="popular-categories__grid">
      {%- for block in section.blocks -%}
        {%- assign category_url = block.settings.collection.url | default: block.settings.link -%}
        {%- if category_url != blank -%}
          <a href="{{ category_url }}" class="category-card" {{ block.shopify_attributes }}>
        {%- else -%}
          <article class="category-card" {{ block.shopify_attributes }}>
        {%- endif -%}
            <div class="category-card__image-wrapper">
              {%- if block.settings.image != blank -%}
                <img 
                  src="{{ block.settings.image | image_url: width: 200 }}" 
                  alt="{{ block.settings.image.alt | escape }}"
                  class="category-card__image"
                  loading="lazy"
                  width="200"
                  height="{{ 200 | divided_by: block.settings.image.aspect_ratio | ceil }}"
                >
              {%- elsif block.settings.collection.image != blank -%}
                <img 
                  src="{{ block.settings.collection.image | image_url: width: 200 }}" 
                  alt="{{ block.settings.collection.image.alt | escape }}"
                  class="category-card__image"
                  loading="lazy"
                  width="200"
                  height="{{ 200 | divided_by: block.settings.collection.image.aspect_ratio | ceil }}"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'category-card__image placeholder-svg' }}
              {%- endif -%}
            </div>
            {%- if block.settings.overline != blank -%}
              <p class="category-card__eyebrow">{{ block.settings.overline | escape }}</p>
            {%- endif -%}
            <h3 class="category-card__title">{{ block.settings.title | default: block.settings.collection.title | default: 'Category' }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="category-card__text">{{ block.settings.description | escape }}</p>
            {%- endif -%}
            <span class="category-card__cta">{{ block.settings.link_label | default: 'Shop category' | escape }}</span>
        {%- if category_url != blank -%}
          </a>
        {%- else -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Popular categories",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Section label",
      "default": "Shop by intent"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Popular categories"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Guide shoppers with more contextual category cards that feel intentional, not just utilitarian.</p>"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "soft", "label": "Soft contrast" }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback link",
          "info": "Used only when no collection is selected"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Overrides the collection image"
        },
        {
          "type": "text",
          "id": "overline",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom heading",
          "info": "Overrides the collection title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popular categories",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
