{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "ai:gateway": "tsx --tsconfig tsconfig.server.json server/ai-gateway.ts",
    "ai:gateway:watch": "tsx watch --tsconfig tsconfig.server.json server/ai-gateway.ts",
    "shopify:dev": "shopify theme dev --path shopify-theme",
    "shopify:pull": "shopify theme pull --path shopify-theme",
    "shopify:push": "shopify theme push --path shopify-theme"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@shopify/cli": "^3.93.2",
    "@shopify/theme": "^3.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
